#!/usr/bin/env bash
# .githooks/pre-commit
# 1. Runs tests to prevent broken commits
# 2. Updates the "Last updated" timestamp in README.md

set -e

# ── Run tests ──────────────────────────────────────────────────────────────
echo "pre-commit: Running tests..."
if ! npm test 2>&1; then
  echo ""
  echo "pre-commit: ❌ Tests failed. Fix failing tests before committing."
  exit 1
fi
echo "pre-commit: ✅ All tests passed."

README="README.md"

if [ ! -f "$README" ]; then
  echo "pre-commit: README.md not found, skipping update"
  exit 0
fi

TODAY=$(date +%Y-%m-%d)

# Replace the date between the LAST_UPDATED markers
sed -i '' \
  "s|_Last updated: .*_|_Last updated: ${TODAY}_|" \
  "$README"

# Stage the updated README so the new date is included in this commit
git add "$README"

echo "pre-commit: README.md updated (Last updated: ${TODAY})"
